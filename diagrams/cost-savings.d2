# Token Economy - Cost Savings

direction: right

# Without GBNF
without: {
  label: |md
    ## 💸 WITHOUT GBNF
    
    **1,000 API calls**
    
    **150 tokens × 1,000 = 150,000 tokens**
    
    **Cost: $0.075**
  |
  
  style: {
    fill: "#ffebee"
    stroke: "#c62828"
  }
  
  # Stacked bars showing token distribution
  signal: {
    shape: rectangle
    label: "Signal: 30,000"
    height: 60
    style: {
      fill: "#c8e6c9"
    }
  }
  
  noise: {
    shape: rectangle
    label: "Noise: 120,000"
    height: 240
    style: {
      fill: "#ffcdd2"
    }
  }
}

# Arrow
arrow: {
  shape: diamond
  label: |md
