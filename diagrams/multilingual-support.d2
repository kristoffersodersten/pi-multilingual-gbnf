# Filtration layer
noise: {
  shape: rectangle
  label: |md
    ## 🧹 NOISE FILTER
    
    **Filtered OUT:**
    • "Certainly"
    • "Absolut"
    • "Natürlich"
    • "Por supuesto"
    • "Bien sûr"
    • etc.
    
    **Preserved:**
  |
  
  style: {
    fill: "#ffebee"
    stroke: "#c62828"
    stroke-dash: 5
  }
}

# Connect languages to noise filter
languages.en -> noise: {style.stroke: "#90a4ae"}
languages.sv -> noise: {style.stroke: "#90a4ae"}
languages.de -> noise: {style.stroke: "#90a4ae"}
languages.es -> noise: {style.stroke: "#90a4ae"}
languages.fr -> noise: {style.stroke: "#90a4ae"}
languages.it -> noise: {style.stroke: "#90a4ae"}
languages.pt -> noise: {style.stroke: "#90a4ae"}
languages.nl -> noise: {style.stroke: "#90a4ae"}
languages.pl -> noise: {style.stroke: "#90a4ae"}

result: {
  shape: cylinder
  label: |md
    ## 🎯 RESULT
    
    **Universal Signal**
    
    All languages: 95% signal
    Same efficiency
    Same structure
  |
  
  style: {
    fill: "#e8f5e9"
    stroke: "#2e7d32"
    stroke-width: 3
  }
}

noise -> result: {
  style.stroke: "#4caf50"
  style.stroke-width: 4
}
